<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WhisperToInput" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <!-- <item name="colorPrimary">@color/my_dark_primary</item> -->
    </style>

    <style name="RegularImage">
        <item name="tint">@color/playful_blue</item>
    </style>

    <style name="RegularText">
        <item name="android:textColor">@color/playful_white</item>
    </style>

    <style name="Background">
        <item name="android:background">@color/dark_blue</item>
    </style>

    <style name="TopBar">
        <item name="android:background">@color/playful_yellow</item>
    </style>

    <style name="SmallCornerButton" parent="Widget.AppCompat.Button.Small">
        <item name="android:background">@drawable/button_feedback</item>
        <item name="android:textColor">@color/playful_white</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">35dp</item>
        <item name="android:height">35dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="SmallCornerImageButton">
        <item name="android:background">@drawable/button_feedback</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:tint">@color/playful_white</item>
        <item name="android:padding">6dp</item>
        <item name="android:minHeight">35dp</item>
        <item name="android:height">35dp</item>
    </style>

</resources>